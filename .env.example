DATABASE_URL=postgresql://tiktok:tiktok@localhost:5432/tiktok_monitor

# App
ENV=development
JWT_SECRET=change-me-to-a-long-random-string
# Use the same hostname everywhere (localhost OR 127.0.0.1, not both).
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ADMIN_EMAIL=you@example.com

# OAuth — Google: https://console.cloud.google.com/
# Redirect URI: http://localhost:8000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create Products in Dashboard: $15/mo, $150/yr per platform)
STRIPE_PRICE_TIKTOK_MONTH=
STRIPE_PRICE_TIKTOK_YEAR=
STRIPE_PRICE_THREADS_MONTH=
STRIPE_PRICE_THREADS_YEAR=

# Adminer UI: http://localhost:8080
# System: PostgreSQL | Server: postgres | User: tiktok | Password: tiktok | Database: tiktok_monitor
